{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@minecraft/server": ["node_modules/bc-minecraft-bedrock-types/server"],
      "@minecraft/server-ui": ["node_modules/bc-minecraft-bedrock-types/server-ui"],
      "@minecraft/server-admin": ["node_modules/bc-minecraft-bedrock-types/server-admin"],
      "@minecraft/server-net": ["node_modules/bc-minecraft-bedrock-types/server-net"],
      "@minecraft/debug-utilities": ["node_modules/bc-minecraft-bedrock-types/debug-utilities"]
    }
  },
  "include": ["behavior_pack/scripts/**/*.ts"]
}